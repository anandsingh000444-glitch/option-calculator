{
  "version": 2,
  "builds": [
    { "src": "api/upstox-chain.js", "use": "@vercel/node" },
    { "src": "api/angel-greeks.js", "use": "@vercel/node" },
    { "src": "api/upstox-auth.js",  "use": "@vercel/node" },
    { "src": "api/market-news.js", "use": "@vercel/node" },
    { "src": "api/worldmonitor.js", "use": "@vercel/node" },
    { "src": "api/stooq-quotes.js", "use": "@vercel/node" },
    { "src": "api/gdelt.js", "use": "@vercel/node" },
    { "src": "api/yahoo-quotes.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/upstox-chain", "dest": "/api/upstox-chain.js" },
    { "src": "/api/angel-greeks", "dest": "/api/angel-greeks.js" },
    { "src": "/api/upstox-auth",  "dest": "/api/upstox-auth.js"  },
    { "src": "/api/market-news",  "dest": "/api/market-news.js"  },
    { "src": "/api/worldmonitor", "dest": "/api/worldmonitor.js" },
    { "src": "/api/stooq-quotes", "dest": "/api/stooq-quotes.js" },
    { "src": "/api/gdelt",        "dest": "/api/gdelt.js" },
    { "src": "/api/yahoo-quotes", "dest": "/api/yahoo-quotes.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
